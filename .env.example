# Google AI API Key (Gemini)
# 取得方式: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# =============================================================================
# 輸出設定
# =============================================================================
# 輸出目錄 (預設: ~/arxiv-papers)
OUTPUT_DIR=~/arxiv-papers

# 篩選前 N 篇論文 (預設: 10)
TOP_N=10

# =============================================================================
# LLM 設定
# =============================================================================
# 模型名稱 (預設: gemini-2.5-flash)
# 可選: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
LLM_MODEL=gemini-2.5-flash

# 溫度 (預設: 0.1，較低溫度確保穩定輸出)
LLM_TEMPERATURE=0.1

# Thinking Budget (僅 Gemini 2.5 系列支援)
# 0 = 關閉 thinking (預設，推薦用於分類/排名任務)
# 1-24576 = 開啟 thinking 並設定 token 預算
# 注意: 開啟 thinking 會增加成本和延遲
LLM_THINKING_BUDGET=0
